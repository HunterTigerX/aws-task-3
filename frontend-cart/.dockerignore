# Development artifacts and sensitive files  
# Added because they can conflict with container builds and contain local dev data  
node_modules  
npm-debug.log  
yarn-debug.log  
yarn-error.log  
.git  
.gitignore  
.env  
.env.*  
*.md  
*.log  

# Test-related files  
# Added because tests are not needed in production and bloat the image  
coverage  
.nyc_output  
test  
__tests__  

# Build outputs  
# Added because they are regenerated during Docker build and should not be cached  
dist  
build  

# Editor/IDE configurations  
# Added because they are developer-specific and irrelevant in deployment  
.idea  
.vscode  
*.swp  
*.swo  

# Operating system metadata files  
# Added because they are OS-generated and useless in a container  
.DS_Store  
Thumbs.db  